{
    "output": "HDMI-A-1",
    "reload_style_on_change": true,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "active-only": false,
        "all-outputs": false,
        "disable-scroll": true,
        "sort-by-number": true,
        "filter": [2, 4, 6, 8, 10],
        "on-click": "activate",
    },

    "layer": "top",
    "position": "bottom",
    "spacing": 8,
    "reload_style_on_change": true,
}
